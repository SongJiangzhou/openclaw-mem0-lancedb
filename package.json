{
  "name": "openclaw-mem0-lancedb",
  "version": "0.1.0",
  "description": "OpenClaw memory plugin with Mem0 + LanceDB",
  "main": "dist/src/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "rebuild": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "test": "node --test --test-concurrency=1 dist/tests/**/*.test.js",
    "install-plugin": "bash scripts/install.sh",
    "install-plugin:zh": "bash scripts/install_zh.sh",
    "mem0:setup": "uv venv && uv pip install mem0ai fastapi uvicorn pydantic google-genai",
    "mem0:start": "uv run uvicorn scripts.mem0_server:app --port 8000"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@clack/prompts": "^1.1.0",
    "@lancedb/lancedb": "^0.26.2",
    "ai": "^6.0.116"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/src/index.js"
    ]
  }
}
