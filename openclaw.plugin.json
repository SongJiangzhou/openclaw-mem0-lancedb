{
  "id": "openclaw-mem0-lancedb",
  "name": "Mem0 + LanceDB Memory",
  "description": "OpenClaw memory plugin using Mem0 as control plane and LanceDB as retrieval layer",
  "version": "0.1.0",
  "kind": "memory",
  "entry": "dist/src/index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "lancedbPath": {
        "type": "string",
        "default": "~/.openclaw/workspace/data/memory_lancedb"
      },
      "mem0": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["local", "remote", "disabled"],
            "default": "remote"
          },
          "baseUrl": {
            "type": "string",
            "default": "https://api.mem0.ai"
          },
          "apiKey": {
            "type": "string",
            "default": ""
          }
        }
      },
      "outboxDbPath": {
        "type": "string",
        "default": "~/.openclaw/workspace/data/outbox.db"
      },
      "auditStorePath": {
        "type": "string",
        "default": "~/.openclaw/workspace/data/memory_audit/memory_records.jsonl"
      },
      "debug": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["off", "basic", "verbose"],
            "default": "off"
          },
          "logDir": {
            "type": "string"
          }
        }
      },
      "autoRecall": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "topK": {
            "type": "number",
            "default": 8
          },
          "maxChars": {
            "type": "number",
            "default": 1400
          },
          "scope": {
            "type": "string",
            "enum": ["long-term", "all"],
            "default": "all"
          }
        }
      },
      "autoCapture": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "scope": {
            "type": "string",
            "enum": ["long-term", "session"],
            "default": "long-term"
          },
          "requireAssistantReply": {
            "type": "boolean",
            "default": true
          },
          "maxCharsPerMessage": {
            "type": "number",
            "default": 2000
          }
        }
      },
      "embeddingMigration": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "intervalMs": {
            "type": "number",
            "default": 900000
          },
          "batchSize": {
            "type": "number",
            "default": 20
          }
        }
      }
    }
  }
}
