{
  "id": "openclaw-mem0-lancedb",
  "name": "Mem0 + LanceDB Memory",
  "description": "OpenClaw memory plugin using Mem0 as control plane and LanceDB as retrieval layer",
  "version": "0.1.0",
  "kind": "memory",
  "entry": "dist/index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "lancedbPath": {
        "type": "string",
        "default": "~/.openclaw/workspace/data/memory_lancedb"
      },
      "mem0BaseUrl": {
        "type": "string",
        "default": "https://api.mem0.ai"
      },
      "mem0ApiKey": {
        "type": "string"
      },
      "outboxDbPath": {
        "type": "string",
        "default": "~/.openclaw/workspace/data/outbox.db"
      },
      "auditStorePath": {
        "type": "string",
        "default": "~/.openclaw/workspace/data/memory_audit/memory_records.jsonl"
      },
      "autoRecall": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "topK": {
            "type": "number",
            "default": 5
          },
          "maxChars": {
            "type": "number",
            "default": 800
          },
          "scope": {
            "type": "string",
            "enum": ["long-term", "all"],
            "default": "all"
          }
        }
      },
      "autoCapture": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "scope": {
            "type": "string",
            "enum": ["long-term", "session"],
            "default": "long-term"
          },
          "requireAssistantReply": {
            "type": "boolean",
            "default": true
          },
          "maxCharsPerMessage": {
            "type": "number",
            "default": 2000
          }
        }
      }
    }
  }
}
